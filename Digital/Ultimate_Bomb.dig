          <string>clk,rst,en,D:8</string>
        </entry>
        <entry>
          <string>Code</string>
          <string>library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity Max_Register is
    Port (
        clk : in  STD_LOGIC;
        rst : in  STD_LOGIC;  -- 接 New_Bomb 或 系統 Reset
        en  : in  STD_LOGIC;  -- 接 Load_Max
        D   : in  STD_LOGIC_VECTOR(7 downto 0); -- 接玩家輸入的數字
        Q   : out STD_LOGIC_VECTOR(7 downto 0)  -- 輸出給顯示器
    );
end Max_Register;

architecture Behavioral of Max_Register is
    -- 預設為 BCD 碼的 99 (1001 1001)
    signal reg_data : STD_LOGIC_VECTOR(7 downto 0) := &quot;10011001&quot;; 
begin
    process(clk, rst)
    begin
        -- 當 rst=1 (收到 New_Bomb 訊號) 時，強制恢復成 99
        if rst = &apos;1&apos; then
            reg_data &lt;= &quot;10011001&quot;; 
        elsif rising_edge(clk) then
            if en = &apos;1&apos; then
                if unsigned(D) &lt; unsigned(reg_data) then
                    reg_data &lt;= D; -- 只有輸入數字比當前範圍小時，才會更新
                end if;
            end if;
        end if;
    end process;
    
    Q &lt;= reg_data;
end Behavioral;</string>
