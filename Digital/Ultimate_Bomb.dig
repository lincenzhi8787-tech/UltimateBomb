        <entry>
          <string>Code</string>
          <string>library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity Mode_Selector is
    Port (
        clk      : in  STD_LOGIC;
        rst      : in  STD_LOGIC;
        btn_mode : in  STD_LOGIC;
        Mode_Out : out STD_LOGIC_VECTOR(1 downto 0)
    );
end Mode_Selector;

architecture Behavioral of Mode_Selector is
    signal mode_reg : unsigned(1 downto 0) := &quot;00&quot;;
    signal btn_prev : std_logic := &apos;0&apos;;
begin

    process(clk, rst)
    begin
        if rst = &apos;1&apos; then
            mode_reg &lt;= &quot;00&quot;;
            btn_prev &lt;= &apos;0&apos;;
        elsif rising_edge(clk) then
            -- 按鍵上升緣偵測 (避免按住時連續瘋狂跳動)
            if btn_mode = &apos;1&apos; and btn_prev = &apos;0&apos; then
                mode_reg &lt;= mode_reg + 1;
            end if;
            btn_prev &lt;= btn_mode;
        end if;
    end process;

    Mode_Out &lt;= std_logic_vector(mode_reg);

end Behavioral;</string>
        </entry>
